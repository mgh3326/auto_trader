    {
      "type": "note",
      "id": "gPjYA",
      "x": 1600,
      "y": 920,
      "name": "Wireframe B Notes",
      "width": 1440,
      "height": 200,
      "content": "WIREFRAME B: Panel-Split Layout\n\n- Top bar navigation (horizontal, compact 56px)\n- Left: Full-width screening table\n- Right: Dark detail panel with report + order combined\n- Table row click opens detail in right panel\n- Pros: More table columns visible, detail panel for focused work\n- Cons: Navigation context switch, less familiar for dashboard users\n- Horizontal nav saves vertical space for data"
    },
